PORT=4200
HOST=0.0.0.0
NODE_ENV=production
FRONTEND_DIST=../dist
DATA_DIR=./data
STORAGE_DIR=./storage
LOG_DIR=./logs
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Default dibuat mengikuti command field yang sudah terbukti jalan:
# copy + rtsp_transport tcp + HLS MPEG-TS.
# Bisa dioverride per kamera dari form: HLS Mode dan RTSP Transport.
STREAM_PROFILE=copy
RTSP_TRANSPORT=tcp
HLS_START_TIMEOUT_MS=20000
STREAM_IDLE_MS=15000
RTSP_TIMEOUT_OPTION=none
STREAM_READ_TIMEOUT_US=0
FFMPEG_LOG_LEVEL=warning
FFMPEG_LOG_TO_CONSOLE=false
FFMPEG_LOG_TO_FILE=false
STREAM_ERROR_RETENTION_MS=300000
STREAM_ERROR_BYTES=12000

# Audit log aman, append-only, dan dipangkas otomatis.
AUDIT_RETENTION_MS=7776000000
AUDIT_MAX_RECORDS=100000

REQUIRE_AUTH=true
AUTH_SECRET=ganti-dengan-secret-panjang-random
# Untuk dashboard internal/VPN, default paling mudah adalah allow semua origin.
# Backend tetap pakai token auth, jadi CORS hanya untuk akses browser.
CORS_ORIGIN=*

# Stream tuning MJPEG
MJPEG_START_TIMEOUT_MS=10000
MJPEG_FPS=8
MJPEG_WIDTH=854
MJPEG_QUALITY=7

# ONVIF PTZ tuning
PTZ_CONNECT_TIMEOUT_MS=9000
PTZ_SOCKET_TIMEOUT_MS=5000
PTZ_COMMAND_TIMEOUT_MS=1800
PTZ_MOVE_DURATION_MS=650
PTZ_SPEED=0.35
PTZ_CLIENT_CACHE_MS=600000

# Go2RTC Port Configuration
GO2RTC_API_PORT=1984
GO2RTC_RTSP_PORT=8554
GO2RTC_WEBRTC_PORT=8555
